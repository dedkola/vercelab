VERCLAB_BASE_DOMAIN=myhomelan.com
VERCLAB_ADMIN_HOST=verclab.myhomelan.com
VERCLAB_PROXY_NETWORK=verclab_proxy
VERCLAB_PROXY_ENTRYPOINT=websecure
VERCLAB_HOST_ROOT=/opt/verclab
VERCLAB_DOCKER_SOCKET_PATH=/var/run/docker.sock
VERCLAB_DATABASE_PROVIDER=sqlite
VERCLAB_POSTGRES_URL=
VERCLAB_ENCRYPTION_SECRET=replace-me-with-a-random-secret